n5 [ shape=octagon, label="out", color="black", fontcolor="black" ];
c6 [ shape=record, label="{{<p1> a|<p4> b}|and_2\nAnd|{<p5> out}}",  ];
c7 [ shape=record, label="{{<p1> a|<p4> b}|nand_1\nNand|{<p5> out}}",  ];
c8 [ shape=record, label="{{<p1> a|<p4> b}|or_0\nOr|{<p5> out}}",  ];
n1:e -> c7:p1:w [color="black", fontcolor="black", label=""];
