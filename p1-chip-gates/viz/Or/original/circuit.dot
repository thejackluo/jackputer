digraph "Or" {
label="Or";
rankdir="LR";
remincross=true;
n1 [ shape=octagon, label="a", color="black", fontcolor="black" ];
n2 [ shape=octagon, label="b", color="black", fontcolor="black" ];
n3 [ shape=diamond, label="na", color="black", fontcolor="black" ];
n4 [ shape=diamond, label="nb", color="black", fontcolor="black" ];
n5 [ shape=octagon, label="out", color="black", fontcolor="black" ];
c6 [ shape=record, label="{{<p1> a|<p2> b}|nand_2\nNand|{<p5> out}}",  ];
c8 [ shape=record, label="{{<p7> in}|not_0\nNot|{<p5> out}}",  ];
c9 [ shape=record, label="{{<p7> in}|not_1\nNot|{<p5> out}}",  ];
n1:e -> c8:p7:w [color="black", fontcolor="black", label=""];
n2:e -> c9:p7:w [color="black", fontcolor="black", label=""];
c8:p5:e -> n3:w [color="black", fontcolor="black", label=""];
n3:e -> c6:p1:w [color="black", fontcolor="black", label=""];
c9:p5:e -> n4:w [color="black", fontcolor="black", label=""];
n4:e -> c6:p2:w [color="black", fontcolor="black", label=""];
c6:p5:e -> n5:w [color="black", fontcolor="black", label=""];
}
