digraph "Not" {
label="Not";
rankdir="LR";
remincross=true;
n1 [ shape=octagon, label="in", color="black", fontcolor="black" ];
n2 [ shape=octagon, label="out", color="black", fontcolor="black" ];
c5 [ shape=record, label="{{<p3> a|<p4> b}|nand_0\nNand|{<p2> out}}",  ];
n1:e -> c5:p3:w [color="black", fontcolor="black", label=""];
n1:e -> c5:p4:w [color="black", fontcolor="black", label=""];
c5:p2:e -> n2:w [color="black", fontcolor="black", label=""];
}
