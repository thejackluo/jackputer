digraph "FullAdder" {
label="FullAdder";
rankdir="LR";
remincross=true;
n1 [ shape=octagon, label="a", color="black", fontcolor="black" ];
n2 [ shape=diamond, label="aAb", color="black", fontcolor="black" ];
n3 [ shape=diamond, label="aAc", color="black", fontcolor="black" ];
n4 [ shape=diamond, label="aObOc", color="black", fontcolor="black" ];
n5 [ shape=diamond, label="aXb", color="black", fontcolor="black" ];
n6 [ shape=octagon, label="b", color="black", fontcolor="black" ];
n7 [ shape=diamond, label="bAc", color="black", fontcolor="black" ];
n8 [ shape=octagon, label="c", color="black", fontcolor="black" ];
n9 [ shape=octagon, label="carry", color="black", fontcolor="black" ];
n10 [ shape=octagon, label="sum", color="black", fontcolor="black" ];
c12 [ shape=record, label="{{<p1> a|<p6> b}|and_2\nAnd|{<p11> out}}",  ];
c13 [ shape=record, label="{{<p1> a|<p6> b}|and_3\nAnd|{<p11> out}}",  ];
c14 [ shape=record, label="{{<p1> a|<p6> b}|and_4\nAnd|{<p11> out}}",  ];
