c16 [ shape=record, label="{{<p1> a|<p6> b}|or_6\nOr|{<p11> out}}",  ];
c17 [ shape=record, label="{{<p1> a|<p6> b}|xor_0\nXor|{<p11> out}}",  ];
c18 [ shape=record, label="{{<p1> a|<p6> b}|xor_1\nXor|{<p11> out}}",  ];
n1:e -> c12:p1:w [color="black", fontcolor="black", label=""];
