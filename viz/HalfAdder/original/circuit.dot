digraph "HalfAdder" {
label="HalfAdder";
rankdir="LR";
remincross=true;
n1 [ shape=octagon, label="a", color="black", fontcolor="black" ];
n2 [ shape=octagon, label="b", color="black", fontcolor="black" ];
n3 [ shape=octagon, label="carry", color="black", fontcolor="black" ];
n4 [ shape=octagon, label="sum", color="black", fontcolor="black" ];
c6 [ shape=record, label="{{<p1> a|<p2> b}|and_1\nAnd|{<p5> out}}",  ];
c7 [ shape=record, label="{{<p1> a|<p2> b}|xor_0\nXor|{<p5> out}}",  ];
n1:e -> c6:p1:w [color="black", fontcolor="black", label=""];
n1:e -> c7:p1:w [color="black", fontcolor="black", label=""];
n2:e -> c6:p2:w [color="black", fontcolor="black", label=""];
n2:e -> c7:p2:w [color="black", fontcolor="black", label=""];
c6:p5:e -> n3:w [color="black", fontcolor="black", label=""];
c7:p5:e -> n4:w [color="black", fontcolor="black", label=""];
}
